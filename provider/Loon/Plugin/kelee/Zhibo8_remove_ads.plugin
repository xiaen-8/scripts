#!name=直播吧去广告
#!desc=移除信息流广告、横幅广告、弹窗广告、皮肤配置、悬浮挂件、热门搜索，移除青少年模式，精简我的页面。
#!openUrl=https://apps.apple.com/app/id1228058501
#!author=可莉🅥[https://github.com/luestr/ProxyResource/blob/main/README.md]
#!tag=去广告
#!system=
#!system_version=
#!loon_version=3.4.0(962)
#!homepage=https://hub.kelee.one
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/Zhibo8.png
#!date=2026-07-03 08:23:50

[Rewrite]
^https:\/\/headline\.qiumibao\.com\/recommend\/list\? response-body-json-jq '.news|=map(select(.model=="news" or .model=="video"))'

^https:\/\/a\.qiumibao\.com\/found\/\? response-body-json-jq 'map(select(.is_game != true))'

^https:\/\/a\.qiumibao\.com\/ios\/config\/\? response-body-json-del skin advert advert_config mall httpdns reward pgame corner_mark liveshop theme pop live_activity_push

^https:\/\/a\.qiumibao\.com\/ios\/config\/\? response-body-json-jq '.all_sections.match_sections.labels |= (if . then (.blacks_disable |= if . then map(select(. != "游戏")) else . end) | (.show |= if . then map(select(. != "游戏")) else . end) else . end)'

^https:\/\/rn\.qiumibao\.com\/news\/relation\.php$ reject-dict

^https:\/\/guess\.qiumibao\.com\/api\/c\/notice$ reject-dict

^https:\/\/guess\.qiumibao\.com\/api\/c\/pop$ reject-dict

^https:\/\/guess\.qiumibao\.com\/api\/ep\/pop$ reject-dict

^https:\/\/guess\.qiumibao\.com\/api\/c\/banner$ reject-dict
^https:\/\/guess\.qiumibao\.com\/api\/n\/rcd$ response-body-json-del data.banner
^https:\/\/pre-match\.qiumibao\.com\/pre_match_data\/v\d\/\d+-\d+-\d+\/\d+_fund\.htm\? response-body-json-del 'del(.data[] | select(.type == "guide"))'

^https:\/\/guess\.qiumibao\.com\/api\/c\/menu$ response-body-json-del data.banner

^https:\/\/s\.qiumibao\.com\/m\/ios\/json\/zhibo\/zuqiu\/\d+\/match\d+vl\.htm\? response-body-json-del ep_v2 ep_live

^https:\/\/search\.qiumibao\.com\/hot\/word_list$ reject-dict

[MitM]
hostname=headline.qiumibao.com, a.qiumibao.com, rn.qiumibao.com, guess.qiumibao.com, s.qiumibao.com, pre-match.qiumibao.com, search.qiumibao.com